FROM python:3.12-slim

WORKDIR /app

COPY backend/requirements.txt /app/backend/requirements.txt
RUN pip install --no-cache-dir -r /app/backend/requirements.txt

COPY backend /app/backend
COPY docs /app/docs

RUN mkdir -p /app/data/processed/matches
COPY backend/deploy_seed/processed/matches/match_001.json /app/data/processed/matches/match_001.json

RUN mkdir -p /app/data/rag_chunks
COPY backend/deploy_seed/rag_chunks/rag_chunks.json /app/data/rag_chunks/rag_chunks.json

WORKDIR /app/backend

ENV PORT=10000

CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "10000"]
